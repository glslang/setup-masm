{
  "name": "setup-masm",
  "version": "1.4.0",
  "main": "dist/main.js",
  "private": true,
  "description": "Helps set up specific MASM tool into PATH for later usage.",
  "scripts": {
    "build": "tsc",
    "pack": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js",
    "all": "npm run build && npm run pack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glslang/setup-masm.git"
  },
  "keywords": [
    "actions",
    "vs",
    "setup",
    "visual studio",
    "masm",
    "assembler",
    "x86",
    "x64",
    "arm64"
  ],
  "author": "Gonçalo Carvalho",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
